# Server configuration
PORT=5000
NODE_ENV=development

# Database configuration
# Set this to a PostgreSQL connection URI to enable real database storage.
# If omitted or invalid, the backend automatically uses a persistent memory database.
DATABASE_URL=postgresql://username:password@localhost:5432/lifepilot_db

# Security
JWT_SECRET=lifepilot-super-secret-key-change-in-prod-12345

# AI Integration
# Insert your OpenAI API key to enable real GPT-4o-mini schedule optimization and finance parsing.
# If omitted, the backend falls back to its internal custom rule-based lifestyle optimization engine.
OPENAI_API_KEY=your_openai_api_key_here
